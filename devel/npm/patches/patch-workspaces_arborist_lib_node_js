           const target = node.target
+          if (!target) {
+            continue
+          }
           this[_target] = target
-          this[_package] = target.package
+          this[_package] = target.package || {}
           target.linksIn.add(this)
           // reload edges here, because now we have a target
           if (this.parent) {
@@ -1391,10 +1394,42 @@ class Node {
