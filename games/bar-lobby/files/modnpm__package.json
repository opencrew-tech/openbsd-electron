{
  "name": "bar-lobby",
  "type": "module",
  "version": "0.15.2",
  "private": true,
  "description": "Lobby client for the RTS game Beyond All Reason",
  "author": "The BAR Lobby Authors",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beyond-all-reason/bar-lobby.git"
  },
  "main": ".vite/build/main.cjs",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--enable-source-maps electron-forge start",
    "package": "electron-forge package",
    "preview": "electron-forge package && cross-env NODE_OPTIONS=--enable-source-maps NODE_ENV=production electron .",
    "build:win": "electron-builder --config electron-builder.config.ts --win",
    "buildall:win": "npm run package && npm run build:win",
    "build:linux": "electron-builder --config electron-builder.config.ts --linux",
    "buildall:linux": "npm run package && npm run build:linux",
    "build:unpack": "electron-builder --config electron-builder.config.ts --dir",
    "dev-cert": "electron-builder create-self-signed-cert -p \"BAR Team\"",
    "build:win:dev-cert": "cross-env CSC_LINK=\"./BAR Team.pfx\" npm run build:win",
    "postinstall": "electron-builder install-app-deps",
    "release": "electron-builder --config electron-builder.config.ts",
    "lint": "eslint --cache",
    "test": "vitest run tests",
    "pretest:e2e": "electron-forge package",
    "test:e2e": "cross-env playwright test",
    "format": "prettier --experimental-cli --write .",
    "format:check": "prettier --experimental-cli --check .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "concurrently 'npm run typecheck:node' 'npm run typecheck:web'",
    "checks": "concurrently 'npm run typecheck:web' 'npm run typecheck:node' 'npm run lint' 'npm run format:check'",
    "generate-i18n-assets": "node --import=tsx tools/generate-i18n-asset-files.ts"
  },
  "dependencies": {
    "@extractus/feed-extractor": "^7.1.6",
    "@iconify-icons/mdi": "^1.2.48",
    "@iconify/json": "^2.2.362",
    "@iconify/vue": "^5.0.0",
    "@sinclair/typebox": "^0.34.38",
    "@vueuse/core": "^13.5.0",
    "7zip-bin": "file:../node/7zip-bin/node_modules/7zip-bin",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.13.5",
    "chokidar": "^4.0.3",
    "date-fns": "^4.1.0",
    "dexie": "^4.0.11",
    "dompurify": "^3.2.6",
    "flag-icons": "^7.5.0",
    "glob-promise": "^6.0.7",
    "howler": "^2.2.4",
    "json8-merge-patch": "^1.0.5",
    "luaparse": "^0.3.1",
    "marked": "^16.1.1",
    "node-abi": "^4.12.0",
    "node-downloader-helper": "^2.1.9",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.54.2",
    "primeicons": "^6.0.1",
    "primevue": "3.23.0",
    "tachyon-protocol": "^1.18.0",
    "vue-i18n": "^11.1.11",
    "vue-router": "^4.5.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/plugin-vite": "^7.8.1",
    "@playwright/test": "^1.54.2",
    "@types/howler": "^2.2.12",
    "@types/luaparse": "^0.2.12",
    "@types/node": "^22.18.13",
    "@types/wait-on": "^5.3.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "37.3.1",
    "electron-builder": "file:../node/electron-builder/node_modules/electron-builder",
    "electron-updater": "^6.6.2",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-plugin-vue": "^10.3.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "sass": "^1.89.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "unplugin-vue-router": "^0.14.0",
    "vite": "^7.1.11",
    "vite-plugin-static-copy": "^3.1.2",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.3",
    "wait-on": "^8.0.4"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^5.0.10"
  },
  "bundleDependencies": [
    "@extractus/feed-extractor",
    "@iconify-icons/mdi",
    "@iconify/json",
    "@iconify/vue",
    "@sinclair/typebox",
    "@vueuse/core",
    "7zip-bin",
    "ajv",
    "ajv-formats",
    "axios",
    "chokidar",
    "date-fns",
    "dexie",
    "dompurify",
    "flag-icons",
    "glob-promise",
    "howler",
    "json8-merge-patch",
    "luaparse",
    "marked",
    "node-abi",
    "node-downloader-helper",
    "pino",
    "pino-pretty",
    "playwright",
    "primeicons",
    "primevue",
    "tachyon-protocol",
    "vue-i18n",
    "vue-router",
    "ws",
    "bufferutil",
    "utf-8-validate"
  ],
  "overrides": {
    "7zip-bin": "file:../node/7zip-bin/node_modules/7zip-bin",
    "app-builder-bin": "file:../node/app-builder-bin/node_modules/app-builder-bin",
    "electron-builder": "file:../node/electron-builder/node_modules/electron-builder",
    "esbuild": "file:../node/esbuild/node_modules/esbuild",
    "graceful-fs": "file:../node/graceful-fs/node_modules/graceful-fs",
    "@parcel/watcher": "file:../node/parcel-watcher/node_modules/@parcel/watcher",
    "rollup": "file:../node/rollup/node_modules/rollup"
  }
}
